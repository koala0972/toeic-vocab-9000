      "id": "B1-301-002",
      "level": 301,
      "tier": "intermediate",
      "cefr": "B1",
      "toeic_score_min": 650,
      "word": "memo",
      "phonetic": "",
      "pos": [
        "noun"
      ],
      "conjugations": {
        "plural": "memos"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "memo",
          "definition": "n. 備忘錄、便箋（memorandum 的簡寫，公司內部短篇公文）"
        }
      ],
      "examples": [
        {
          "en": "She typed a memo reminding all staff to submit expense reports by Friday.",
          "highlight": [
            "memo"
          ],
          "translations": {
            "zh-TW": "她打了一份備忘錄，提醒全體員工在週五前提交 費用報告。"
          }
        },
        {
          "en": "The manager printed three memos and left them on each team member's desk.",
          "highlight": [
            "memos"
          ],
          "translations": {
            "zh-TW": "經理印了三份便箋，分別放在每位組員的桌上。"
          }
        },
        {
          "en": "Please cc me on any memo regarding the new overtime policy.",
          "highlight": [
            "memo"
          ],
          "translations": {
            "zh-TW": "任何關於新加班規定的備忘錄，請順便副本給我。"
          }
        }
      ],
      "synonyms": [
        "note",
        "memorandum",
        "reminder"
      ],
      "antonyms": [
        "formal report"
      ],
      "phrases": [
        "staff memo",
        "internal memo",
        "write a memo",
        "memo template"
      ]
    },
