      ],
      "examples": [
        {
          "en": "Let's schedule a meeting sometime next week to discuss the rebranding plan.",
          "highlight": [
            "sometime"
          ],
          "translations": {
            "zh-TW": "我們下週找個時間開個會，討論品牌重塑的計畫。"
          }
        },
        {
          "en": "Our sometime partner, Apex Logistics, rebranded last year and now operates under a new name.",
          "highlight": [
            "sometime"
          ],
          "translations": {
            "zh-TW": "我們以前的合作夥伴 Apex 物流去年重新品牌化，現在改用新名稱營運。"
          }
        },
        {
          "en": "The CEO said he would sometime review the proposal if his schedule allowed.",
          "highlight": [
            "sometime"
          ],
          "translations": {
            "zh-TW": "執行長說如果行程允許的話，他改天會審閱那份提案。"
          }
        }
      ],
      "synonyms": [
        "eventually",
        "one day",
        "somewhen"
