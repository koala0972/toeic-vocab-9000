      "cefr": "B1",
      "toeic_score_min": 650,
      "word": "mister",
      "phonetic": "",
      "pos": [
        "noun"
      ],
      "conjugations": {
        "plural": "misters"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "mister",
          "definition": "n. 先生（用於稱呼男性，書面常縮寫為 Mr.）"
        }
      ],
      "examples": [
        {
          "en": "Good morning, Mister Lee, your appointment is scheduled for ten o'clock.",
          "highlight": [
            "Mister"
          ],
          "translations": {
            "zh-TW": "早安，李先生，您的預約排在十點鐘。"
          }
        },
        {
          "en": "The misters from the accounting department will join the audit meeting tomorrow.",
          "highlight": [
            "misters"
          ],
          "translations": {
            "zh-TW": "會計部的幾位先生明天會一起參加稽核會議。"
          }
        },
        {
          "en": "Please address the letter to Mister David Chen, Purchasing Manager.",
          "highlight": [
            "Mister"
          ],
          "translations": {
            "zh-TW": "這封信請寄給採購經理陳大衛先生。"
          }
        }
      ],
      "synonyms": [
        "sir",
        "gentleman",
        "Mr."
      ],
      "antonyms": [
        "madam",
        "miss"
      ],
      "phrases": [
        "Mister Right",
        "mister president",
        "good morning mister"
      ]
    },
