      "toeic_score_min": 650,
      "word": "urgent",
      "phonetic": "ˈɜːrdʒənt",
      "pos": [
        "adjective"
      ],
      "conjugations": {
        "comparative": "more urgent",
        "superlative": "most urgent"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "urgent",
          "definition": "adj. 緊急的、急迫的"
        }
      ],
      "examples": [
        {
          "en": "The manager sent an urgent email asking everyone to attend the meeting immediately.",
          "highlight": [
            "urgent"
          ],
          "translations": {
            "zh-TW": "經理發了一封緊急的電子郵件，要求所有人立刻出席會議。"
          }
        },
        {
          "en": "As the deadline approached, the request became more urgent than ever.",
          "highlight": [
            "more urgent"
          ],
          "translations": {
            "zh-TW": "隨著截止日期逼近，這項要求變得比以往更加急迫。"
          }
        },
        {
          "en": "Of all the issues on the agenda, the budget cut was the most urgent.",
          "highlight": [
            "most urgent"
          ],
          "translations": {
            "zh-TW": "在議程的所有議題中，預算縮減是最為緊急的。"
          }
        }
      ],
      "synonyms": [
        "pressing",
        "critical",
        "imperative"
      ],
      "antonyms": [
        "minor",
        "unimportant"
      ],
      "phrases": [
        "urgent need",
        "urgent matter",
        "urgent message",
        "urgent care"
      ]
    },
