      "examples": [
        {
          "en": "The inspector found it illogical that the report listed expenses without receipts.",
          "highlight": [
            "illogical"
          ],
          "translations": {
            "zh-TW": "稽查員覺得這份報告列出開支卻沒有收據，完全不合邏輯。"
          }
        },
        {
          "en": "Rejecting a qualified candidate for being too experienced is more illogical than rejecting one for being inexperienced.",
          "highlight": [
            "more illogical"
          ],
          "translations": {
            "zh-TW": "因求職者經驗過於豐富而拒絕他，比因經驗不足而拒絕更加說不通。"
          }
        },
        {
          "en": "Of all the decisions the committee made, cutting training budgets to boost productivity was the most illogical.",
          "highlight": [
            "most illogical"
          ],
          "translations": {
            "zh-TW": "在委員會所有決策中，削減培訓預算來提升生產力最為不合邏輯。"
          }
        }
      ],
      "synonyms": [
        "irrational",
        "unreasonable",
        "inconsistent"
      ],
      "antonyms": [
        "logical",
        "rational",
        "reasonable"
      ],
      "phrases": [
        "illogical argument",
        "illogical conclusion",
        "illogical reasoning",
        "completely illogical"
      ]
    },
