          "translations": {
            "zh-TW": "命題人員必須確保每個誘答選項看似合理卻明顯錯誤。"
          }
        },
        {
          "en": "Smart distractors in the reading section often trick students who skim too quickly.",
          "highlight": [
            "distractors"
          ],
          "translations": {
            "zh-TW": "閱讀測驗中高明的干擾選項常常絆倒閱讀過快的學生。"
          }
        }
