      "cefr": "B1",
      "toeic_score_min": 650,
      "word": "unreal",
      "pos": [
        "adjective"
      ],
      "conjugations": {
        "comparative": "unrealler",
        "superlative": "unreallest"
      },
      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "unreal",
          "definition": "a. 不真實的、虛構的、幻想的；誇張的"
        }
      ],
      "examples": [
        {
          "en": "The graphics in the new game looked so real that they felt almost unreal.",
          "highlight": [
            "unreal"
          ],
          "translations": {
            "zh-TW": "新遊戲的畫面逼真得讓人覺得簡直像不真實的場景。"
          }
        },
        {
          "en": "Investors dismissed the startup's projections as unrealler than reality, demanding hard data.",
          "highlight": [
            "unrealler"
          ],
          "translations": {
            "zh-TW": "投資人認為新創公司的預測比現實更不切實際，要求他們提出具體數據。"
          }
        },
        {
          "en": "That product launch was the unreallest success story the team had ever seen.",
          "highlight": [
            "unreallest"
          ],
          "translations": {
            "zh-TW": "那場產品發表會是團隊見過最不真實的成功故事。"
          }
        }
      ],
      "synonyms": [
        "unbelievable",
        "incredible",
        "fantastic"
      ],
      "antonyms": [
        "real",
        "authentic"
      ],
      "phrases": [
        "seem unreal",
        "unreal world",
        "unreal engine",
        "feel unreal"
      ]
    },
