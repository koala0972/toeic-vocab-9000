        {
          "en": "We had to resubmit the paperworks twice because of missing signatures on the application forms.",
          "highlight": [
            "paperworks"
          ],
          "translations": {
            "zh-TW": "我們必須重新提交書面文件兩次，因為申請表上少了簽名。"
          }
        },
        {
          "en": "Most of her day at the accounting firm is spent sorting through paperwork rather than meeting clients.",
          "highlight": [
            "paperwork"
          ],
          "translations": {
            "zh-TW": "她在會計事務所的大部分時間都在整理文書，而非與客戶會面。"
          }
