      "id": "B1-303-001",
      "level": 303,
      "tier": "intermediate",
      "cefr": "B1",
      "toeic_score_min": 650,
      "word": "traveler",
      "phonetic": "",
      "pos": [
        "noun"
      ],
      "conjugations": {
        "plural": "travelers"
      },
      "domain": "travel",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "traveler",
          "definition": "n. 旅行者、旅客、遊客"
        }
      ],
      "examples": [
        {
          "en": "The business traveler booked a nonstop flight to Tokyo to save time.",
          "highlight": [
            "traveler"
          ],
          "translations": {
            "zh-TW": "這位商務旅客訂了一班直飛東京的班機以節省時間。"
          }
        },
        {
          "en": "Frequent travelers can accumulate enough miles for a free upgrade.",
          "highlight": [
            "travelers"
          ],
          "translations": {
            "zh-TW": "常旅客能累積足夠的里程數來兌換免費升等。"
          }
        },
        {
          "en": "Travelers without a valid visa may be denied boarding at the gate.",
          "highlight": [
            "Travelers"
          ],
          "translations": {
            "zh-TW": "沒有有效簽證的旅客可能會在登機門被拒絕登機。"
          }
        }
      ],
      "synonyms": [
        "tourist",
        "passenger",
        "wayfarer"
      ],
      "antonyms": [
        "resident",
        "local"
      ],
      "phrases": [
        "business traveler",
        "frequent traveler",
        "traveler's check",
        "traveler's insurance"
      ]
    },
