      "domain": "cognition",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "infer",
          "definition": "vt. 推論出、推斷  vi. 作出推論"
        }
      ],
      "examples": [
        {
          "en": "Scientists can infer the climate of ancient times from ice core samples.",
          "highlight": [
            "infer"
          ],
          "translations": {
            "zh-TW": "科學家能從冰芯樣本推論出古代的氣候。"
          }
        },
        {
          "en": "The analyst inferred a decline in demand after reviewing three quarters of sales data.",
          "highlight": [
            "inferred"
          ],
          "translations": {
            "zh-TW": "分析師在檢視三季的銷售數據後，推斷需求正在下降。"
          }
        },
        {
          "en": "Inferring intent from an email alone can lead to serious misunderstandings.",
          "highlight": [
            "Inferring"
          ],
          "translations": {
            "zh-TW": "僅憑一封電子郵件就推斷對方的意圖，可能會造成嚴重的誤解。"
          }
        }
      ],
      "synonyms": [
        "deduce",
        "conclude",
        "surmise"
      ],
      "antonyms": [
        "state",
        "declare"
      ],
