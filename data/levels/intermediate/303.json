      "domain": "transportation",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "subway",
          "definition": "n. 地下鐵、捷運、地下道"
        }
      ],
      "examples": [
        {
          "en": "Taking the subway is often faster than driving during rush hour in Manhattan.",
          "highlight": [
            "subway"
          ],
          "translations": {
            "zh-TW": "在曼哈頓，尖峰時段搭地下鐵通常比開車更快。"
          }
        },
        {
          "en": "New subways are under construction to relieve traffic congestion in the city center.",
          "highlight": [
            "subways"
          ],
          "translations": {
            "zh-TW": "市中心正在興建新的地下鐵，以紓解交通擁塞。"
          }
        },
        {
          "en": "Subways in most major cities operate at least eighteen hours a day.",
          "highlight": [
            "Subways"
          ],
          "translations": {
            "zh-TW": "大多數主要城市的地下鐵每天至少營運十八小時。"
          }
        }
      ],
      "synonyms": [
        "metro",
        "underground",
        "tube"
      ],
      "antonyms": [
        "overpass",
        "elevated railway"
      ],
      "phrases": [
        "subway station",
        "subway map",
        "subway pass",
        "take the subway"
      ]
    },
