          "lang": "zh-TW",
          "lang_word": "shipment",
          "definition": "n. 裝運、出貨、運送的貨物"
        }
      ],
      "examples": [
        {
          "en": "The shipment of electronic components arrived a day earlier than scheduled.",
          "highlight": [
            "shipment"
          ],
          "translations": {
            "zh-TW": "這批電子零件的裝運比預定時間早一天抵達。"
          }
        },
        {
          "en": "International shipments require customs documents before they can be released.",
          "highlight": [
            "shipments"
          ],
          "translations": {
            "zh-TW": "國際出貨需要通關文件才能放行。"
          }
        },
        {
          "en": "Shipments containing fragile items must be marked with a warning label.",
          "highlight": [
            "Shipments"
          ],
          "translations": {
            "zh-TW": "含有易碎品的出貨必須標示警告標籤。"
          }
        }
      ],
      "synonyms": [
        "delivery",
        "consignment",
        "freight"
      ],
      "antonyms": [
        "pickup",
        "collection"
      ],
