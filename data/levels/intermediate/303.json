      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "warranty",
          "definition": "n. 保證、保固、保單、擔保書"
        }
      ],
      "examples": [
        {
          "en": "Each laptop comes with a one-year warranty that covers manufacturing defects.",
          "highlight": [
            "warranty"
          ],
          "translations": {
            "zh-TW": "每台筆記型電腦都附有一年保固，涵蓋製造瑕疵。"
          }
        },
        {
          "en": "Extended warranties often generate more profit than the appliances themselves.",
          "highlight": [
            "warranties"
          ],
          "translations": {
            "zh-TW": "延長保單創造的利潤往往比家電本身還要高。"
          }
        },
        {
          "en": "Warranties labelled \"limited\" usually exclude damage caused by the user.",
          "highlight": [
            "Warranties"
          ],
          "translations": {
            "zh-TW": "標示為「有限」的保固通常不涵蓋人為造成的損壞。"
          }
        }
      ],
      "synonyms": [
        "guarantee",
        "pledge",
        "assurance"
      ],
      "antonyms": [
        "disclaimer"
      ],
      "phrases": [
        "under warranty",
        "extended warranty",
        "limited warranty",
        "warranty period"
      ]
