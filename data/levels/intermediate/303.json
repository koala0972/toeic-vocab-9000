          "lang": "zh-TW",
          "lang_word": "caller",
          "definition": "n. 來電者、打電話的人、來訪者"
        }
      ],
      "examples": [
        {
          "en": "The caller refused to leave a message when the manager was unavailable.",
          "highlight": [
            "caller"
          ],
          "translations": {
            "zh-TW": "經理不在時，這位來電者拒絕留下口信。"
          }
        },
        {
          "en": "Experienced receptionists can identify angry callers within the first few words.",
          "highlight": [
            "callers"
          ],
          "translations": {
            "zh-TW": "經驗豐富的接待員能在最初幾句話內辨識出生氣的來電者。"
          }
        },
        {
          "en": "Callers who remain on hold for more than three minutes tend to hang up.",
          "highlight": [
            "Callers"
          ],
          "translations": {
            "zh-TW": "等待超過三分鐘的來電者通常會直接掛斷。"
          }
        }
      ],
      "synonyms": [
        "phoner",
        "visitor"
      ],
      "antonyms": [
        "recipient"
      ],
      "phrases": [
        "caller ID",
        "caller waiting",
        "frequent caller",
        "anonymous caller"
      ]
