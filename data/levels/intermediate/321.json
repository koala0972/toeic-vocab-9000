      "synonyms": [
        "voluntary",
        "elective",
        "discretionary"
      ],
      "antonyms": [
        "mandatory",
        "required",
        "compulsory"
      ],
      "phrases": [
        "optional extra",
        "optional course",
        "optional equipment",
        "optional parameter"
      ]
