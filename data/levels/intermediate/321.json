          ],
          "translations": {
            "zh-TW": "這項展覽吸引了超過五百名免費試用的參加者。"
          }
        },
        {
          "en": "As a price taker, the small firm must accept the prevailing market rate.",
          "highlight": [
            "taker"
          ],
          "translations": {
            "zh-TW": "作為價格接受者，這家小公司必須接受目前的市場價格。"
          }
        }
      ],
      "synonyms": [
        "acceptor",
        "recipient",
