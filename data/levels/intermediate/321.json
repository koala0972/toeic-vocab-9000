      "id": "B1-321-001",
      "level": 321,
      "tier": "intermediate",
      "cefr": "B1",
      "toeic_score_min": 650,
      "word": "graph",
      "phonetic": "ɡræf",
      "pos": [
        "noun"
      ],
      "conjugations": {
        "plural": "graphs"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "graph",
          "definition": "n. 圖表、曲線圖、關係圖"
        }
      ],
      "examples": [
        {
          "en": "The sales manager displayed a graph showing monthly revenue growth.",
          "highlight": [
            "graph"
          ],
          "translations": {
            "zh-TW": "業務經理展示了一張顯示每月營收成長的圖表。"
          }
        },
        {
          "en": "The analyst compared several graphs to identify the market trend.",
          "highlight": [
            "graphs"
          ],
          "translations": {
            "zh-TW": "分析師比對了好幾張圖表，以找出市場趨勢。"
          }
        },
        {
          "en": "Please plot the quarterly profit on the graph so the board can see the decline.",
          "highlight": [
            "graph"
          ],
          "translations": {
            "zh-TW": "請將季度利潤標示在圖表上，好讓董事會看到下滑的趨勢。"
          }
        }
      ],
      "synonyms": [
        "chart",
        "diagram",
        "plot"
      ],
      "antonyms": [],
      "phrases": [
        "bar graph",
        "line graph",
        "pie graph",
        "graph paper"
      ]
    },
