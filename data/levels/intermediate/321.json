      "phonetic": "ˈmɪnɪmaɪz",
      "pos": [
        "verb"
      ],
      "conjugations": {
        "present_3rd": "minimizes",
        "past": "minimized",
        "past_participle": "minimized",
        "ing": "minimizing"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "minimize",
          "definition": "v. 將…減到最少、最小化、輕視、低估"
        }
      ],
      "examples": [
        {
          "en": "The factory installed new filters to minimize air pollution.",
          "highlight": [
            "minimize"
          ],
          "translations": {
            "zh-TW": "工廠安裝了新的過濾設備，以將空氣污染降到最低。"
          }
        },
        {
          "en": "The company minimized its losses by selling the division before the market collapsed.",
          "highlight": [
            "minimized"
          ],
          "translations": {
            "zh-TW": "公司在市場崩盤前賣掉那個部門，將損失降到最低。"
          }
        },
        {
          "en": "By minimizing overhead costs, the startup extended its runway by six months.",
          "highlight": [
            "minimizing"
          ],
          "translations": {
            "zh-TW": "透過最小化營運開銷，這家新創公司延長了六個月的資金跑道。"
          }
        }
      ],
      "synonyms": [
        "reduce",
        "decrease",
        "lessen"
      ],
      "antonyms": [
        "maximize",
        "increase"
      ],
      "phrases": [
        "minimize risk",
        "minimize costs",
        "minimize damage",
        "minimize window"
      ]
    },
