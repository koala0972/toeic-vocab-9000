      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "alike",
          "definition": "a. 相似的、同樣的  adv. 同樣地、以相同方式"
        }
      ],
      "examples": [
        {
          "en": "The two branch offices look remarkably alike in layout and branding.",
          "highlight": [
            "alike"
          ],
          "translations": {
            "zh-TW": "兩家分公司在格局與品牌形象上看起來非常相似。"
          }
        },
        {
          "en": "All employees, regardless of rank, are treated alike under the new company policy.",
          "highlight": [
            "alike"
          ],
          "translations": {
            "zh-TW": "根據公司新政策，所有員工不論職位高低都受到相同對待。"
          }
        },
        {
          "en": "The twins dress alike and often finish each other's sentences during meetings.",
          "highlight": [
            "alike"
          ],
          "translations": {
            "zh-TW": "那對雙胞胎穿著相似，開會時經常接完對方的話。"
          }
        }
