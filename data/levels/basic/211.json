      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "personally",
          "definition": "adv. 親自地、就個人而言、當面地"
        }
      ],
      "examples": [
        {
          "en": "I will personally inspect the new factory next Monday.",
          "highlight": [
            "personally"
          ],
          "translations": {
            "zh-TW": "我下週一會親自去視察新工廠。"
          }
        },
        {
          "en": "Personally, I think the merger is a wise decision.",
          "highlight": [
            "Personally"
          ],
          "translations": {
            "zh-TW": "就我個人而言，我認為這次併購是明智的決定。"
          }
        },
        {
          "en": "The manager personally apologized to every customer affected by the delay.",
          "highlight": [
            "personally"
          ],
          "translations": {
            "zh-TW": "經理親自向每一位因延遲而受影響的顧客致歉。"
          }
        }
      ],
      "synonyms": [
        "directly",
        "in person"
      ],
      "antonyms": [
        "indirectly"
      ],
      "phrases": [
        "personally speaking",
        "personally responsible",
        "know someone personally"
      ]
    },
