      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "ambulance",
          "definition": "(n.) 救護車、急救車（用於運送傷病患的專用車輛）"
        }
      ],
      "examples": [
        {
          "en": "The ambulance arrived at the scene within ten minutes of the emergency call.",
          "highlight": [
            "ambulance"
          ],
          "translations": {
            "zh-TW": "救護車在報案後十分鐘內抵達了事故現場。"
          }
        },
        {
          "en": "Several ambulances were lined up outside the hospital during the accident.",
          "highlight": [
            "ambulances"
          ],
          "translations": {
            "zh-TW": "那場事故發生時，好幾輛救護車在醫院外面排成一列。"
          }
        },
        {
          "en": "When someone collapsed in the office, the receptionist immediately called an ambulance.",
          "highlight": [
            "ambulance"
          ],
          "translations": {
            "zh-TW": "當有人在辦公室暈倒時，櫃台人員立刻叫了救護車。"
          }
        }
      ],
      "synonyms": [
        "emergency vehicle",
        "rescue vehicle"
      ],
      "antonyms": [],
      "phrases": [
        "call an ambulance",
        "ambulance service",
        "by ambulance",
        "ambulance driver"
      ]
