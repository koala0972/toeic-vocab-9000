      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "actual",
          "definition": "adj. 真實的、實際的、現行的"
        }
      ],
      "examples": [
        {
          "en": "The actual cost of the project was much higher than the original estimate.",
          "highlight": [
            "actual"
          ],
          "translations": {
            "zh-TW": "這項專案的實際成本比原本的估計高出許多。"
          }
