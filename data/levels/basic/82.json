      "domain": "finance",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "debt",
          "definition": "n. 債務、欠款  v. 借貸、使負債"
        }
      ],
      "examples": [
        {
          "en": "The company is struggling to pay off its debt to the bank.",
          "highlight": [
            "debt"
          ],
          "translations": {
            "zh-TW": "公司正努力償還欠銀行的債務。"
          }
        },
        {
          "en": "After years of overspending, his debts had grown to an unmanageable level.",
          "highlight": [
            "debts"
          ],
          "translations": {
            "zh-TW": "經過多年入不敷出，他的債務已增加到無法負擔的程度。"
          }
        },
        {
          "en": "She debted herself further by taking out a second mortgage on her house.",
          "highlight": [
            "debted"
          ],
          "translations": {
            "zh-TW": "她用自己的房子再貸一筆款，讓自己陷入了更深的負債。"
          }
        }
      ],
      "synonyms": [
        "liability",
        "arrears",
        "obligation"
      ],
      "antonyms": [
        "credit",
        "asset"
      ],
