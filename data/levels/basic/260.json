      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "similarly",
          "definition": "adv. 相似地、類似地、同樣地"
        }
      ],
      "examples": [
        {
          "en": "The two companies are similarly structured, with flat management hierarchies.",
          "highlight": [
            "similarly"
          ],
          "translations": {
            "zh-TW": "這兩家公司的架構相似，都採用扁平的管理層級。"
          }
        },
        {
          "en": "Similarly, the Tokyo branch reported a decline in quarterly sales.",
          "highlight": [
            "Similarly"
          ],
          "translations": {
            "zh-TW": "同樣地，東京分公司也回報了季度營收下滑。"
          }
        },
        {
          "en": "The new interns were treated similarly to the full-time staff during training.",
          "highlight": [
            "similarly"
          ],
          "translations": {
            "zh-TW": "在培訓期間，新進實習生受到與全職員工相似的待遇。"
          }
        }
      ],
      "synonyms": [
        "likewise",
        "correspondingly",
        "comparably"
      ],
      "antonyms": [
        "differently",
        "dissimilarly"
      ],
      "phrases": [
        "similarly situated",
        "similarly affected",
        "treat similarly"
      ]
    },
