      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "confident",
          "definition": "adj. 有信心的、有把握的"
        }
      ],
      "examples": [
        {
          "en": "She felt confident about her presentation to the board of directors.",
          "highlight": [
            "confident"
          ],
          "translations": {
            "zh-TW": "她對向董事會做的簡報感到有信心。"
          }
        },
        {
          "en": "The more confident candidate usually performs better in job interviews.",
          "highlight": [
            "more confident"
          ],
          "translations": {
            "zh-TW": "在求職面試中，更有信心的候選人通常表現得更好。"
          }
        },
        {
          "en": "He is the most confident member of our sales team when dealing with difficult clients.",
          "highlight": [
            "most confident"
          ],
          "translations": {
            "zh-TW": "在應付難搞的客戶時，他是我們銷售團隊中最有信心的一員。"
          }
        }
