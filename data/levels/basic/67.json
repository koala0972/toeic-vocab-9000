        "past": "confined",
        "past_participle": "confined",
        "ing": "confining"
      },
      "domain": "business",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "confine",
          "definition": "v. 限制、使局限、把…限制在（某範圍內）"
        }
      ],
      "examples": [
        {
          "en": "Please confine your remarks to the agenda items listed in the meeting invitation.",
          "highlight": [
            "confine"
          ],
          "translations": {
            "zh-TW": "請將您的發言限制在會議邀請函中所列的議程項目內。"
          }
        },
        {
          "en": "The manager confined the discussion to budget issues during yesterday's teleconference.",
          "highlight": [
            "confined"
          ],
          "translations": {
            "zh-TW": "在昨天的電話會議中，經理把討論限制在預算問題上。"
          }
        },
        {
          "en": "He has been confining his research to renewable energy companies in Asia for the last three years.",
          "highlight": [
            "confining"
          ],
          "translations": {
            "zh-TW": "過去三年來，他一直將研究範圍局限於亞洲的可再生能源公司。"
          }
        }
      ],
      "synonyms": [
        "restrict",
        "limit",
        "restrain"
      ],
      "antonyms": [
        "free",
        "release"
      ],
      "phrases": [
        "confine to",
        "confine within",
        "be confined to",
        "confine oneself to"
      ]
    },
