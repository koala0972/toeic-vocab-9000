      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "excite",
          "definition": "vt. 激發、使興奮、引起  n. 興奮、刺激"
        }
      ],
      "examples": [
        {
          "en": "The new product launch excited a lot of interest among investors.",
          "highlight": [
            "excited"
          ],
          "translations": {
            "zh-TW": "新產品發表在投資人之間引起了高度興趣。"
          }
        },
        {
          "en": "Her bold idea has been exciting the team since she first presented it.",
          "highlight": [
            "exciting"
          ],
          "translations": {
            "zh-TW": "自從她首次提出以來，她大膽的想法一直令團隊振奮不已。"
          }
        },
        {
          "en": "The professor's lecture excites even the most skeptical students.",
          "highlight": [
            "excites"
          ],
          "translations": {
            "zh-TW": "這位教授的演講連最持懷疑態度的學生都能被激發興趣。"
          }
        }
      ],
      "synonyms": [
        "stimulate",
        "thrill",
        "arouse"
