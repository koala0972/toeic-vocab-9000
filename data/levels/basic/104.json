      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "embarrassed",
          "definition": "a. 尷尬的、窘迫的、難為情的"
        }
      ],
      "examples": [
        {
          "en": "The manager looked embarrassed when the client caught the error in the report.",
          "highlight": [
            "embarrassed"
          ],
          "translations": {
            "zh-TW": "客戶發現報告中的錯誤時，經理看起來相當尷尬。"
          }
        },
