      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "realistic",
          "definition": "a. 現實的、實際可行的、逼真的"
        }
      ],
      "examples": [
        {
          "en": "The manager gave a realistic estimate of how long the project would take.",
          "highlight": [
            "realistic"
