          "translations": {
            "zh-TW": "經理對專案需要多長時間提出了實際可行的估計。"
          }
        },
        {
          "en": "Her plan was more realistic than mine, so the board approved hers instead.",
          "highlight": [
            "more realistic"
          ],
          "translations": {
            "zh-TW": "她的計畫比我的更切合實際，所以董事會改通過了她的。"
          }
        },
        {
          "en": "This is the most realistic budget we have ever prepared for the marketing team.",
          "highlight": [
            "most realistic"
          ],
          "translations": {
            "zh-TW": "這是我們為行銷團隊準備過最務實的預算。"
          }
        }
      ],
      "synonyms": [
        "practical",
        "sensible",
        "down-to-earth"
