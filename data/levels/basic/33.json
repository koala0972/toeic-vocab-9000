          "highlight": [
            "based"
          ],
          "translations": {
            "zh-TW": "顧問以從兩百多家公司收集到的資料為依據提出了建議。"
          }
        },
        {
          "en": "Headquarters has based its new research team in Singapore to better serve Asian clients.",
          "highlight": [
            "based"
          ],
          "translations": {
            "zh-TW": "總公司將新研究團隊駐紮在新加坡，以更妥善地服務亞洲客戶。"
          }
        }
