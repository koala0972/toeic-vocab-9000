      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "neatly",
          "definition": "adv. 整齊地、乾淨地、俐落地"
        }
      ],
      "examples": [
        {
          "en": "Please file these documents neatly in the cabinet before the audit.",
          "highlight": [
            "neatly"
          ],
          "translations": {
            "zh-TW": "請在稽核前把這些文件整齊地歸檔到櫃子裡。"
          }
        },
        {
          "en": "The new intern arranged the display shelves neatly to impress the store manager.",
          "highlight": [
            "neatly"
          ],
          "translations": {
            "zh-TW": "新進實習生把展示架整齊地排列好，想給店長留下好印象。"
          }
        },
        {
          "en": "He folded the letter neatly and slipped it into the envelope for the client.",
          "highlight": [
            "neatly"
          ],
          "translations": {
            "zh-TW": "他把信件俐落地摺好，塞進給客戶的信封裡。"
          }
        }
      ],
      "synonyms": [
        "tidily",
        "cleanly",
        "trimly"
      ],
      "antonyms": [
        "messily",
        "untidily"
      ],
      "phrases": [
        "neatly dressed",
        "neatly arranged",
        "write neatly",
        "fold neatly"
      ]
