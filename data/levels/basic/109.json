      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "environment",
          "definition": "n. 環境、周圍狀況、自然環境"
        }
      ],
      "examples": [
        {
          "en": "The company is committed to protecting the natural environment by reducing waste emissions.",
          "highlight": [
            "environment"
          ],
          "translations": {
            "zh-TW": "這家公司透過減少廢氣排放來致力保護自然環境。"
          }
        },
        {
          "en": "Modern office environments are designed to boost employee productivity and well-being.",
          "highlight": [
            "environments"
          ],
          "translations": {
            "zh-TW": "現代辦公環境旨在提升員工的生產力與身心健康。"
          }
        },
        {
          "en": "Children develop linguistic skills rapidly in a multilingual learning environment.",
          "highlight": [
            "environment"
          ],
          "translations": {
            "zh-TW": "在多語言的學習環境中，兒童的語言能力發展得非常迅速。"
          }
        }
      ],
      "synonyms": [
        "surroundings",
        "habitat",
        "setting"
      ],
      "antonyms": [],
      "phrases": [
        "natural environment",
        "working environment",
        "protect the environment",
        "business environment"
      ]
