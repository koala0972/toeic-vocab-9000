      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "humorous",
          "definition": "a. 富幽默感的、滑稽的、詼諧的"
        }
      ],
      "examples": [
        {
          "en": "The speaker gave a humorous opening remark that relaxed the whole room.",
