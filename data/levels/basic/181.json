        {
          "lang": "zh-TW",
          "lang_word": "meanwhile",
          "definition": "adv. 同時、在此期間  n. 其間、其時"
        }
      ],
      "examples": [
        {
          "en": "Meanwhile, the marketing team prepared the new campaign materials.",
          "highlight": [
            "Meanwhile"
          ],
          "translations": {
            "zh-TW": "同時，行銷團隊準備了新的宣傳活動素材。"
          }
        },
        {
          "en": "The CEO was negotiating the merger; meanwhile, the employees worried about layoffs.",
          "highlight": [
            "meanwhile"
          ],
          "translations": {
            "zh-TW": "執行長正在談判併購案；在此期間，員工們擔心裁員。"
          }
        },
        {
          "en": "Please wait in the lobby in the meanwhile; the doctor will see you shortly.",
          "highlight": [
            "meanwhile"
          ],
          "translations": {
            "zh-TW": "請在此期間在大廳等候，醫生很快會為您看診。"
          }
        }
      ],
      "synonyms": [
        "in the meantime",
