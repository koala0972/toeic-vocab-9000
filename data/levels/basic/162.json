      "id": "A2-162-001",
      "level": 162,
      "tier": "basic",
      "cefr": "A2",
      "toeic_score_min": 200,
      "word": "january",
      "pos": [
        "noun",
        "proper noun"
      ],
      "conjugations": {
        "plural": "januaries"
      },
      "domain": "calendar",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "january",
          "definition": "n. 一月（公曆第一個月）"
        }
      ],
      "examples": [
        {
          "en": "The new fiscal year begins in January, so we need to finalize the budget by December.",
          "highlight": [
            "January"
          ],
          "translations": {
            "zh-TW": "新財政年度從一月開始，所以我們必須在十二月底前定案預算。"
          }
        },
        {
          "en": "Last January was the coldest in a decade, with snow closing several offices.",
          "highlight": [
            "January"
          ],
          "translations": {
            "zh-TW": "去年一月是十年來最冷的一月，大雪甚至讓幾間辦公室關閉。"
          }
        },
        {
          "en": "She has two Januaries to remember: the one she started her job and the one she got promoted.",
          "highlight": [
            "Januaries"
          ],
          "translations": {
            "zh-TW": "她有兩個難忘的一月：一個是她開始上班的那年，另一個是她升職的那年。"
          }
        }
      ],
      "synonyms": [
        "first month",
        "winter month"
      ],
      "antonyms": [
        "December"
      ],
      "phrases": [
        "in January",
        "January 1st",
        "mid-January",
        "late January"
      ]
    },
