      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "shocked",
          "definition": "a. 震驚的、驚愕的  v. 使震驚（shock 的過去式與過去分詞）"
        }
      ],
      "examples": [
        {
          "en": "The CEO was shocked by the sudden drop in quarterly profits.",
          "highlight": [
            "shocked"
          ],
          "translations": {
            "zh-TW": "執行長對季度利潤的突然下滑感到震驚。"
          }
        },
        {
          "en": "The new policy has shocked the entire industry.",
          "highlight": [
            "shocked"
          ],
          "translations": {
            "zh-TW": "這項新政策震驚了整個產業。"
          }
        },
        {
          "en": "Investors remain shocked at the committee's unexpected decision.",
          "highlight": [
            "shocked"
          ],
          "translations": {
            "zh-TW": "投資人對委員會出乎意料的決定仍感到震驚。"
          }
        }
      ],
      "synonyms": [
        "stunned",
        "astonished",
        "appalled"
      ],
      "antonyms": [
        "unshocked",
        "unmoved"
      ],
      "phrases": [
        "shocked by the news",
        "shocked into silence",
        "shocked expression"
      ]
    },
