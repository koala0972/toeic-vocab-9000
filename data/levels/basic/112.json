      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "exaggerate",
          "definition": "v. 誇大、誇張、言過其實"
        }
      ],
      "examples": [
        {
          "en": "Salespeople often exaggerate the benefits of a product to close the deal.",
          "highlight": [
            "exaggerate"
          ],
          "translations": {
            "zh-TW": "業務員常把產品的好處誇大，以促成交易。"
          }
        },
