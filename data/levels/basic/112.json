          "highlight": [
            "exaggerated"
          ],
          "translations": {
            "zh-TW": "面試時這名應徵者誇大了他在專案中的角色。"
          }
        },
        {
          "en": "Stop exaggerating the risks — the investment is actually quite safe.",
          "highlight": [
            "exaggerating"
          ],
          "translations": {
            "zh-TW": "別再誇大風險了——這項投資其實相當安全。"
          }
        }
      ],
      "synonyms": [
        "overstate",
        "embellish",
