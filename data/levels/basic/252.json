      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "selection",
          "definition": "n. 選擇、挑選、精選品、選拔"
        }
      ],
      "examples": [
        {
          "en": "The store offers a wide selection of office supplies for corporate clients.",
          "highlight": [
            "selection"
          ],
          "translations": {
            "zh-TW": "這家店為企業客戶提供種類繁多的辦公用品供選擇。"
          }
        },
        {
          "en": "The manager reviewed the candidates' selections before the final interview round.",
          "highlight": [
            "selections"
          ],
          "translations": {
            "zh-TW": "經理在最終面試前審查了候選人的各項選擇紀錄。"
          }
        },
        {
          "en": "Careful selection of suppliers is critical to maintaining product quality.",
          "highlight": [
            "selection"
          ],
          "translations": {
            "zh-TW": "謹慎挑選供應商對維持產品品質至關重要。"
          }
        }
      ],
      "synonyms": [
        "choice",
        "pick",
        "option"
