      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "bike",
          "definition": "n. 自行車  v. 騎自行車"
        }
      ],
      "examples": [
        {
          "en": "She locks her bike to the railing in front of the office every morning.",
          "highlight": [
            "bike"
          ],
          "translations": {
            "zh-TW": "她每天早上把自行車鎖在辦公室前面的欄杆上。"
          }
        },
        {
          "en": "To save money on his commute, Jack began biking to work instead of driving his car.",
          "highlight": [
            "biking"
          ],
          "translations": {
            "zh-TW": "為了省通勤費，傑克開始騎自行車上班，不再開車。"
          }
        },
        {
          "en": "The courier company reported a sharp rise in the use of company-owned bikes for next-day deliveries.",
          "highlight": [
            "bikes"
          ],
          "translations": {
            "zh-TW": "物流公司表示，「隔日送達」服務使公司配發的自行車使用量大幅上升。"
          }
        }
      ],
      "synonyms": [
        "bicycle",
        "cycle"
      ],
      "antonyms": [
        "car"
      ],
      "phrases": [
        "ride a bike",
