      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "fighter",
          "definition": "n. 戰士、鬥士、格鬥者、戰鬥機"
        }
      ],
      "examples": [
        {
          "en": "The young boxer proved to be a talented fighter in the ring.",
