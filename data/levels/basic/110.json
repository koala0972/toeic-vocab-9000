      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "essential",
          "definition": "adj. 必要的、不可或缺的  n. 要素、必需品"
        }
      ],
      "examples": [
        {
          "en": "Good communication skills are essential for any manager in a multinational company.",
          "highlight": [
            "essential"
