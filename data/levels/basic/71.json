      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "continuously",
          "definition": "adv. 持續地、連續不斷地"
        }
      ],
      "examples": [
        {
          "en": "The factory has been operating continuously for 48 hours to meet the deadline.",
          "highlight": [
            "continuously"
          ],
          "translations": {
            "zh-TW": "為了趕上截止日期，工廠已連續運轉了四十八小時。"
          }
        },
        {
          "en": "Rain fell continuously throughout the weekend, flooding several streets downtown.",
          "highlight": [
            "continuously"
          ],
          "translations": {
            "zh-TW": "整個週末雨下個不停，導致市中心幾條街道淹水。"
          }
        },
        {
          "en": "Investors have monitored the stock continuously since the merger announcement.",
          "highlight": [
            "continuously"
          ],
          "translations": {
            "zh-TW": "自從併購消息宣布後，投資人便持續關注這檔股票。"
          }
        }
