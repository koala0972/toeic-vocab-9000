      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "initiative",
          "definition": "n. 主動、主動權、倡議  a. 自發的、起始的"
        }
      ],
      "examples": [
        {
          "en": "She took the initiative to organize the team-building event without being asked.",
