          }
        },
        {
          "en": "The new intern impressed the manager by finishing the report two days early.",
          "highlight": [
            "impressed"
          ],
          "translations": {
            "zh-TW": "新來的實習生提前兩天完成報告，令經理印象深刻。"
          }
        },
        {
          "en": "Her presentation was so impressing that several clients asked for a follow-up meeting.",
          "highlight": [
            "impressing"
          ],
          "translations": {
            "zh-TW": "她的簡報令人印象深刻，好幾位客戶都要求安排後續會議。"
          }
        }
