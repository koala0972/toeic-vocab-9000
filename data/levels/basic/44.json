      "cefr": "A1",
      "toeic_score_min": 200,
      "word": "bridge",
      "pos": [
        "noun",
        "verb"
      ],
      "conjugations": {
        "plural": "bridges",
        "present_3rd": "bridges",
        "past": "bridged",
        "past_participle": "bridged",
        "ing": "bridging"
      },
      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "bridge",
          "definition": "n. 橋樑、橋、橋樑連接  v. 跨越、架橋、彌合（分歧）"
        }
      ],
      "examples": [
        {
          "en": "The new bridge connects the island to the mainland and shortens the commute by twenty minutes.",
          "highlight": [
            "bridge"
          ],
          "translations": {
            "zh-TW": "這座新橋將小島與大陸連接起來，把通勤時間縮短了二十分鐘。"
          }
        },
        {
          "en": "The manager bridged the gap between two departments by holding weekly joint meetings.",
          "highlight": [
            "bridged"
          ],
          "translations": {
            "zh-TW": "經理每週舉行聯合會議，彌合了兩個部門之間的隔閡。"
          }
        },
        {
          "en": "Engineers are bridging the river with a temporary steel structure during repairs.",
          "highlight": [
            "bridging"
          ],
          "translations": {
            "zh-TW": "在維修期間，工程師正以臨時鋼結構架橋跨越這條河。"
          }
        }
      ],
      "synonyms": [
        "span",
        "overpass",
        "link"
      ],
      "antonyms": [
        "gap",
        "divide"
      ],
      "phrases": [
        "bridge the gap",
        "cross the bridge",
        "build a bridge"
      ]
    },
