      "domain": "behavior",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "tendency",
          "definition": "n. 傾向、趨勢、癖好"
        }
      ],
      "examples": [
        {
          "en": "There is a growing tendency among consumers to shop online.",
          "highlight": [
            "tendency"
          ],
          "translations": {
            "zh-TW": "消費者上網購物的傾向日益增加。"
          }
        },
        {
          "en": "The manager noticed several tendencies in the sales data over the past quarter.",
          "highlight": [
            "tendencies"
          ],
          "translations": {
            "zh-TW": "經理注意到過去一季的銷售數據中出現了幾個趨勢。"
          }
        },
        {
          "en": "His tendency to arrive late has become a serious problem for the team.",
          "highlight": [
            "tendency"
          ],
          "translations": {
            "zh-TW": "他老是遲到的傾向已經成了團隊的一個嚴重問題。"
          }
        }
      ],
      "synonyms": [
        "inclination",
        "propensity",
        "lean"
      ],
      "antonyms": [
        "reluctance",
        "unwillingness"
      ],
      "phrases": [
        "natural tendency",
        "show a tendency",
        "have a tendency to",
        "growing tendency"
      ]
