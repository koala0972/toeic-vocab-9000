      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "lonely",
          "definition": "a. 孤獨的、寂寞的、荒涼的"
        }
      ],
      "examples": [
        {
          "en": "After her husband passed away, she felt lonely in the big house.",
          "highlight": [
            "lonely"
          ],
          "translations": {
            "zh-TW": "丈夫過世後，她在大房子裡感到孤獨。"
          }
        },
        {
          "en": "The winter nights in the cabin felt even lonelier than the summer ones.",
          "highlight": [
            "lonelier"
          ],
          "translations": {
            "zh-TW": "小木屋裡的冬夜比夏夜更顯寂寞。"
          }
        },
        {
          "en": "He drove down the loneliest highway in the country, with no other car in sight for miles.",
          "highlight": [
            "loneliest"
          ],
          "translations": {
            "zh-TW": "他駛上全國最荒涼的公路，數英里內不見其他車輛。"
          }
        }
      ],
      "synonyms": [
        "isolated",
        "lonesome",
        "solitary"
      ],
      "antonyms": [
        "sociable",
        "accompanied"
      ],
      "phrases": [
