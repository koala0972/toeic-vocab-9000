      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "mess",
          "definition": "n. 混亂、髒亂  v. 弄糟、搞亂"
        }
      ],
      "examples": [
        {
          "en": "After the office relocation, the storage room was a complete mess.",
          "highlight": [
            "mess"
          ],
          "translations": {
            "zh-TW": "辦公室搬遷之後，儲藏室亂成一團。"
          }
        },
        {
          "en": "The new intern messed up the invoice numbers and we had to reprint all the copies.",
          "highlight": [
            "messed"
          ],
          "translations": {
            "zh-TW": "新來的實習生把發票編號搞錯了，我們只好重新列印所有副本。"
          }
        },
        {
          "en": "Stop messing with the printer settings or the whole department will not be able to scan documents.",
          "highlight": [
            "messing"
          ],
          "translations": {
            "zh-TW": "別再亂動印表機的設定了，否則整個部門都沒辦法掃描文件。"
          }
        }
      ],
      "synonyms": [
        "disorder",
        "chaos",
        "jumble"
      ],
      "antonyms": [
        "order",
        "neatness"
      ],
      "phrases": [
        "make a mess",
        "mess up",
        "mess around"
      ]
    },
