    {
      "id": "A2-183-001",
      "level": 183,
      "tier": "basic",
      "cefr": "A2",
      "toeic_score_min": 200,
      "word": "merely",
      "pos": [
        "adverb"
      ],
      "conjugations": {},
      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "merely",
          "definition": "adv. 僅僅、只不過"
        }
      ],
      "examples": [
        {
          "en": "The report merely summarizes the first-quarter results; detailed figures are in the appendix.",
          "highlight": [
            "merely"
          ],
          "translations": {
            "zh-TW": "這份報告只是概述第一季的成果；詳細數據請見附錄。"
          }
        },
        {
          "en": "She merely suggested a minor revision to the contract.",
          "highlight": [
            "merely"
          ],
          "translations": {
            "zh-TW": "她僅僅建議對合約做一處小修改。"
          }
        },
        {
          "en": "He is merely an intern, but his ideas have impressed the whole team.",
          "highlight": [
            "merely"
          ],
          "translations": {
            "zh-TW": "他只不過是個實習生，但他的想法卻令整個團隊刮目相看。"
          }
        }
      ],
      "synonyms": [
        "only",
        "just",
        "simply"
      ],
      "antonyms": [
        "significantly",
        "greatly"
      ],
      "phrases": [
        "merely a suggestion",
        "not merely",
        "merely because"
      ]
    },
    {
      "id": "A2-183-002",
      "level": 183,
      "tier": "basic",
      "cefr": "A2",
      "toeic_score_min": 200,
      "word": "mess",
