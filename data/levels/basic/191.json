      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "nation",
          "definition": "n. 國家、民族"
        }
      ],
      "examples": [
        {
          "en": "The nation celebrated its fiftieth year of independence with parades and fireworks.",
          "highlight": [
            "nation"
          ],
          "translations": {
            "zh-TW": "這個國家以遊行和煙火慶祝獨立五十週年。"
          }
        },
        {
          "en": "Many nations signed the trade agreement to reduce tariffs on agricultural products.",
          "highlight": [
            "nations"
          ],
          "translations": {
            "zh-TW": "許多國家簽署了這項貿易協定，以降低農產品的關稅。"
          }
        },
        {
          "en": "Leaders from the wealthiest nations gathered to discuss global climate policy.",
          "highlight": [
            "nations"
          ],
          "translations": {
            "zh-TW": "來自最富裕國家的領袖齊聚一堂，討論全球氣候政策。"
          }
        }
      ],
      "synonyms": [
