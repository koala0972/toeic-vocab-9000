      "toeic_score_min": 200,
      "word": "honestly",
      "pos": [
        "adverb"
      ],
      "conjugations": {},
      "domain": "general",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "honestly",
          "definition": "adv. 誠實地、坦白地；說真的（用於強調語氣）"
        }
      ],
      "examples": [
        {
          "en": "Honestly, I think we should reconsider the proposal before signing.",
          "highlight": [
            "Honestly"
          ],
          "translations": {
            "zh-TW": "說真的，我認為我們在簽約前應該重新考慮這個提案。"
          }
        },
        {
          "en": "The candidate answered the interviewer's questions honestly and confidently.",
          "highlight": [
            "honestly"
          ],
          "translations": {
            "zh-TW": "求職者誠實而自信地回答了面試官的問題。"
          }
        },
        {
          "en": "Honestly speaking, the new policy has caused more problems than it solved.",
          "highlight": [
            "honestly"
          ],
          "translations": {
            "zh-TW": "坦白說，新政策造成的問題比解決的還要多。"
          }
        }
      ],
      "synonyms": [
        "truthfully",
        "sincerely",
        "candidly"
      ],
      "antonyms": [
        "dishonestly",
        "deceitfully"
      ],
      "phrases": [
        "speak honestly",
        "answer honestly",
        "honestly speaking"
      ]
    },
