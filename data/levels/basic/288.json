      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "then",
          "definition": "adv. 那時、然後、當時 conj. 既然、那麼"
        }
      ],
      "examples": [
        {
          "en": "We finished the meeting, and then everyone headed to the cafeteria.",
