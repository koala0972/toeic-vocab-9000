            "therefore"
          ],
          "translations": {
            "zh-TW": "他沒有通過語言測試，因此沒有獲派海外職位。"
          }
        },
        {
          "en": "The deadline was moved up, so we must therefore finish the design today.",
          "highlight": [
            "therefore"
          ],
          "translations": {
            "zh-TW": "截止日期提前了，所以我們必須今天完成設計。"
          }
