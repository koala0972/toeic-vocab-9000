          "highlight": [
            "then"
          ],
          "translations": {
            "zh-TW": "我那時還是個大學生，買不起車。"
          }
        },
        {
          "en": "If you want the promotion, then you had better finish the report tonight.",
          "highlight": [
            "then"
          ],
          "translations": {
            "zh-TW": "既然你想升職，那麼你最好今晚把報告寫完。"
          }
        }
