      "domain": "medical",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "infection",
          "definition": "n. 感染、傳染、傳染病"
        }
      ],
      "examples": [
        {
          "en": "The doctor confirmed that the patient had a bacterial infection.",
          "highlight": [
            "infection"
          ],
          "translations": {
            "zh-TW": "醫生確認該病患感染了細菌。"
          }
        },
        {
          "en": "Hospital staff work hard to prevent infections from spreading between wards.",
          "highlight": [
            "infections"
          ],
          "translations": {
            "zh-TW": "醫院人員努力防止感染在病房之間傳播。"
          }
        },
        {
          "en": "Early treatment of the infection helped the worker return to duty within a week.",
          "highlight": [
            "infection"
          ],
          "translations": {
            "zh-TW": "及早治療感染讓這名員工一週內就能回到工作崗位。"
          }
        }
      ],
      "synonyms": [
        "contagion",
        "disease",
        "illness"
      ],
      "antonyms": [
        "health",
        "wellness"
      ],
      "phrases": [
        "bacterial infection",
        "viral infection",
        "prevent infection",
        "ear infection"
      ]
    },
    {
      "id": "A2-155-002",
      "level": 155,
      "tier": "basic",
      "cefr": "A2",
      "toeic_score_min": 200,
      "word": "infectious",
      "pos": [
        "adjective"
      ],
      "conjugations": {},
      "domain": "medical",
      "translations": [
        {
          "lang": "zh-TW",
          "lang_word": "infectious",
          "definition": "adj. 有傳染性的、易傳染的"
        }
      ],
      "examples": [
        {
          "en": "Tuberculosis is an infectious disease that spreads through the air.",
          "highlight": [
            "infectious"
          ],
          "translations": {
            "zh-TW": "結核病是一種透過空氣傳播的傳染病。"
          }
        },
        {
          "en": "Her infectious laugh made the whole team feel more relaxed before the presentation.",
          "highlight": [
            "infectious"
          ],
          "translations": {
            "zh-TW": "她那極具感染力的笑聲讓整個團隊在簡報前放鬆了不少。"
          }
        },
        {
          "en": "Patients with infectious conditions are kept in isolation rooms to protect other visitors.",
          "highlight": [
            "infectious"
          ],
          "translations": {
            "zh-TW": "罹患傳染性疾病的病患被安置在隔離病房，以保護其他訪客。"
          }
        }
      ],
      "synonyms": [
        "contagious",
        "communicable",
        "catching"
      ],
      "antonyms": [
        "non-contagious",
        "non-infectious"
      ],
      "phrases": [
        "infectious disease",
        "infectious laugh",
        "highly infectious",
        "infectious agent"
      ]
    },
    {
